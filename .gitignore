# ── Raw per-CV JSON outputs ──────────────────────────────────────────────────
# The master CSVs already contain scores, verdicts and tokens; the JSONs add
# LLM explanations that may quote CV text back. Keep them local for audit.
results/level1*.json
results/level2*.json

# ── Level 3 intermediates ───────────────────────────────────────────────────
# Large or quote-back-prone artefacts. Master CSVs and the matrices needed
# for downstream rendering stay tracked; the rest is local-only.
results/level3/labelled/
results/level3/segments_normalisation/
results/level1_2/
results/level3/llm_labelled_json/
results/level3/llm_labelled_json_cv/
results/level3/factor_analysis/
results/level3/human_rates_l3/

# Internal pipeline notes — not for the public repo
scripts/level3/PIPELINE.md

